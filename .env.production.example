# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME=CronosPulse
APP_ENV=production
APP_KEY=                          # Generate with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://cronospulse.com
APP_TIMEZONE=UTC                  # e.g. America/New_York — used for schedules and display

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=error

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=cronospulse_mysql         # Container name on cronospulse_network
DB_PORT=3306
DB_DATABASE=cronospulse
DB_USERNAME=cronospulse
DB_PASSWORD=                      # Strong random password

# ------------------------------------------------------------------------------
# Cache / Session / Queue
# ------------------------------------------------------------------------------
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=cronospulse_redis      # Container name on cronospulse_network
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Mail
# ------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@cronospulse.com
MAIL_FROM_NAME="CronosPulse"

# ------------------------------------------------------------------------------
# Application-specific
# ------------------------------------------------------------------------------
CONTACT_EMAIL=                    # Where contact form submissions are sent
ADMIN_PASSWORD=                   # Initial admin user password (seeder use)

# ------------------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------------------
FILESYSTEM_DISK=local

# ------------------------------------------------------------------------------
# External APIs
# ------------------------------------------------------------------------------
USGS_EARTHQUAKE_API_URL=https://earthquake.usgs.gov/fdsnws/event/1/
USGS_VOLCANO_API_URL=https://volcanoes.usgs.gov/vsc/api/volcanoApi/
USGS_WATER_SERVICES_API_URL=https://waterservices.usgs.gov/nwis/iv/