{
    "preset": "psr12",
    "rules": {
        "declare_strict_types": true,
        "blank_line_after_namespace": true,
        "blank_line_after_opening_tag": true,
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "single_quote": true,
        "trailing_comma_in_multiline": {
            "elements": ["arrays", "arguments", "parameters"]
        }
    }
}
